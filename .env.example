# Variables para docker-compose (copiar a .env en la raíz del repositorio)

# Puerto publicado en el host → contenedor (debe coincidir con PORT del contenedor salvo mapeo custom)
API_PORT=3000
PORT=3000

# Clave estática para el header X-API-KEY (cambiar en producción)
API_KEY=1234567890

# Orígenes del frontend permitidos por CORS (separados por coma)
# Ejemplos:
#   Desarrollo local: http://localhost:5173
#   Railway: https://tu-frontend.up.railway.app
#   Varios: https://app.ejemplo.com,https://staging.ejemplo.com
CORS_ORIGIN=http://localhost:5173

# Sincronizar esquema SQLite al arrancar (true por defecto en el código si se omite).
# Railway: dejar true en despliegues iniciales; usar volumen en /app/data
DB_SYNCHRONIZE=true

# Obsoleto para cálculo de proformas V2 (IVA por línea); conservado por compatibilidad
IVA_RATE=0.15
