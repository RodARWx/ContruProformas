# URL base del API de Construproformas.
# En desarrollo con `npm run dev`, use /api para aprovechar el proxy de Vite (evita CORS).
# En producción o sin proxy: http://localhost:3000/api
VITE_API_BASE_URL=/api
VITE_API_KEY=1234567890

# PIN de acceso del lado del cliente (no es autenticación de backend)
VITE_ACCESS_PIN=2585
