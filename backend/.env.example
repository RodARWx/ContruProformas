# Puerto interno de NestJS
PORT=3000

# Ruta al archivo SQLite (relativa al directorio backend/)
# Los PDF/Excel exportados se guardan en: {directorio del DATABASE_PATH}/exports/
DATABASE_PATH=../data/construproformas.db

# Sincroniza el esquema automáticamente (true en desarrollo / Docker inicial)
DB_SYNCHRONIZE=true

# Tasa de IVA cuando appliesIva = true (15% Ecuador)
IVA_RATE=0.15

# Clave de acceso estática para proteger la API (encabezado X-API-KEY)
API_KEY=construproformas-dev-key
