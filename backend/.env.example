# Puerto HTTP (Railway y otros PaaS inyectan PORT automáticamente)
PORT=3000

# Ruta al archivo SQLite
# Docker / Railway (volumen persistente): /app/data/construproformas.db
# Desarrollo local (desde backend/): ../data/construproformas.db
#
# Los PDF/Excel exportados se guardan en: {directorio del DATABASE_PATH}/exports/
# Ejemplo Docker: /app/data/exports/
DATABASE_PATH=../data/construproformas.db

# Sincronizar esquema SQLite al arrancar (true por defecto si no se define).
# En Railway / Docker dejar en true hasta contar con migraciones formales.
# Desactivar en producción madura: DB_SYNCHRONIZE=false
DB_SYNCHRONIZE=true

# Orígenes del frontend permitidos por CORS (separados por coma, o * para cualquiera)
# Si no se define, CORS queda deshabilitado (útil cuando el frontend usa proxy en dev)
CORS_ORIGIN=http://localhost:5173

# IVA_RATE ya no se usa en el cálculo de proformas (IVA por línea desde V2 fase 5).
# Se conserva por compatibilidad con despliegues existentes; puede eliminarse en fase futura.
IVA_RATE=0.15

# Clave de acceso estática para proteger la API (encabezado X-API-KEY)
# GET /api/health es público (sin API Key) — healthcheck Docker/Railway
API_KEY=1234567890