# Puerto HTTP (Railway y otros PaaS inyectan PORT automáticamente)
PORT=3000

# Ruta al archivo SQLite
# Docker / Railway (volumen persistente): /app/data/construproformas.db
# Desarrollo local (desde backend/): ../data/construproformas.db
# Prueba rápida en memoria (datos se pierden al reiniciar): :memory:
#
# Los PDF/Excel exportados se guardan en: {directorio del DATABASE_PATH}/exports/
# Ejemplo Docker: /app/data/exports/
DATABASE_PATH=../data/construproformas.db

# Sincronizar esquema SQLite al arrancar (true por defecto si no se define).
# En Railway / Docker dejar en true hasta contar con migraciones formales.
# Desactivar en producción madura: DB_SYNCHRONIZE=false
DB_SYNCHRONIZE=true

# Orígenes del frontend permitidos por CORS (separados por coma).
# Producción Render: https://construproformas-web.onrender.com
# Vacío o * → acepta cualquier origen (útil si el frontend cambia de URL).
# Desarrollo local con proxy Vite: puede omitirse (CORS siempre activo).
CORS_ORIGIN=http://localhost:5173

# IVA_RATE ya no se usa en el cálculo de proformas (IVA por línea desde V2 fase 5).
# Se conserva por compatibilidad con despliegues existentes; puede eliminarse en fase futura.
IVA_RATE=0.15

# Clave de acceso estática para proteger la API (encabezado X-API-KEY)
# GET /api/health es público (sin API Key) — healthcheck Docker/Railway
API_KEY=1234567890

# --- Exportación institucional de proformas ---

# URL base para QR de validación (se concatena /{idProforma})
PROFORMA_VALIDATION_BASE_URL=https://construmetrica.com/validar-proforma

# Logo (opcional; por defecto backend/assets/images/logo-construmetrica.png)
# PROFORMA_LOGO_PATH=/ruta/absoluta/logo.png
# PROFORMA_LOGO_BASE64=

# Fuentes Gotham (opcional; por defecto backend/assets/fonts/)
# PROFORMA_FONT_GOTHAM_BLACK_PATH=
# PROFORMA_FONT_GOTHAM_BOOK_PATH=

# LibreOffice headless para PDF idéntico al Excel
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
# Linux/Docker: /usr/bin/libreoffice (instalado en imagen Docker)
# LIBREOFFICE_PATH=

# Puppeteer fallback (Chromium). Docker: /usr/bin/chromium-browser
# PUPPETEER_EXECUTABLE_PATH=